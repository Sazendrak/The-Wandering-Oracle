# ==============================================================================
# Security & Credentials (CRITICAL)
# ==============================================================================
# Never commit your Discord Bot Token or Avrae API credentials to a public repo
.env
.env.local
.env.*.local
*.env
config.json
credentials.json
secrets/

# ==============================================================================
# System & OS Debris
# ==============================================================================
.DS_Store
Thumbs.db
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==============================================================================
# Node.js / Dependency Management
# ==============================================================================
# Even if your bot script is small, keep dependencies out of the repo
node_modules/
.npm/
.yarn/
package-lock.json
yarn.lock

# ==============================================================================
# Docusaurus & Build Artifacts
# ==============================================================================
# Only commit your final outputs. Do not commit local scratchpads, cache, or local builds.
.docusaurus/
.cache/
build/
dist/
.serverless/

# ==============================================================================
# Editor & IDE Workspace Settings
# ==============================================================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# ==============================================================================
# Python
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
